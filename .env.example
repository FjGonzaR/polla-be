# Local development (app corre fuera de Docker, DB en Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/polla_mundial

# Producción Docker Compose (ambos servicios en la misma red)
# DATABASE_URL=postgresql://postgres:TuPasswordSeguro@db:5432/polla_mundial

PORT=3000
NODE_ENV=development

# Credenciales del servicio 'db' en docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=polla_mundial

WORLDCUP_API_URL=https://worldcup26.ir

# Google OAuth — mismo client ID que el FE usa con @react-oauth/google
GOOGLE_CLIENT_ID=your-google-oauth2-client-id.apps.googleusercontent.com

# Google sub (user ID) of the admin account — no invite code needed for this user
ADMIN_GOOGLE_ID=

# JWT para firmar la cookie de sesión
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=30d

# Cookie: 'lax' si FE y BE comparten dominio, 'none' si son dominios distintos (requiere HTTPS)
COOKIE_SAME_SITE=lax

# CORS: URL del frontend
CORS_ORIGIN=http://localhost:5173

# Para tests — apunta a una DB separada
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/polla_test
