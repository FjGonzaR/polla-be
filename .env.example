# Local development (app corre fuera de Docker, DB en Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/polla_mundial

# Producción Docker Compose (ambos servicios en la misma red)
# DATABASE_URL=postgresql://postgres:TuPasswordSeguro@db:5432/polla_mundial

PORT=3000
NODE_ENV=development

# Credenciales del servicio 'db' en docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=polla_mundial

WORLDCUP_API_URL=https://worldcup26.ir
